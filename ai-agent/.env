# BillerQ API Configuration
BILLERQ_API_BASE=https://admin.billerq.com/public/api
BILLERQ_LOGIN_EMAIL=shikaraj264@gmail.com
BILLERQ_LOGIN_PASSWORD=12345678
BILLERQ_AUTO_LOGIN=true

BILLERQ_INDUSTRY_ID=1

# Demo Mode: when true, returns mock data instead of calling real API
DEMO_MODE=false

# Ollama Configuration (kept for fallback)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# LLM Provider: "ollama" or "bedrock"
LLM_PROVIDER=bedrock

# AWS Bedrock Configuration
# Get these from: AWS Console → IAM → Users → billerqai → Security Credentials → Create access key
AWS_ACCESS_KEY_ID=REPLACE_WITH_YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_SECRET_KEY
# AWS_SESSION_TOKEN=   # Only needed if using temporary credentials / SSO
AWS_REGION=eu-north-1

# Claude Haiku 4.5 model ID (the one visible in your Bedrock Playground)
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0
